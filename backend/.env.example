# ---------- Discord Bot ----------
DISCORD_TOKEN=isi_token_bot_disini
CLIENT_ID=isi_application_id_bot_disini
GUILD_ID=isi_server_id_disini
MOD_LOG_CHANNEL_ID=isi_channel_id_untuk_log_moderasi

# ---------- Permission Role Mapping ----------
# Nama role ini HARUS SAMA PERSIS (case-insensitive) dengan nama role di
# server Discord kamu. Lihat backend/config/permissions.js untuk detail
# kapabilitas tiap role. Kalau nama role di server beda dari default di
# bawah, WAJIB diisi di sini.
ROLE_NAME_OWNER=Owner
ROLE_NAME_DEVELOPER=Developer
ROLE_NAME_EVENT_ORGANIZER=Event Organizer
ROLE_NAME_BRAND_AMBASSADOR=Brand Ambassador
ROLE_NAME_SUPPORTER=Supporter

# ---------- Supabase ----------
# Dapatkan di Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=isi_service_role_key_disini
# PENTING: service_role key BYPASS semua RLS. Jangan pernah taruh di app mobile,
# hanya dipakai di backend/bot ini.
SUPABASE_ANON_KEY=isi_anon_public_key_disini
# anon key ini yang dipakai backend untuk VERIFIKASI token dari app (aman untuk ini),
# dan yang sama juga dipakai di Flutter app untuk login.

# ---------- API Server ----------
API_PORT=3000

# ---------- Firebase (push notification) ----------
# Download service account JSON di Firebase Console -> Project Settings -> Service Accounts
# lalu taruh path filenya di sini
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
